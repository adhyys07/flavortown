<%= link_to sidequest_path("minequest"), class: "sidequest-card sidequest-card--blue sidequest-card--placeholder sidequest-card--link", id: "minequest-placeholder" do %>
  <div class="sidequest-card__content">
    <h1 class="sidequest-card__title">Minequest</h1>
    <div class="sidequest-card__image-placeholder" role="img" aria-label="Minequest placeholder image">
      Replace with Minequest image
    </div>
    <h2>Placeholder quest card for upcoming Minequest details.</h2>

    <div class="sidequest-card__buttons" aria-hidden="true">
      <span class="btn btn-learn-more">Learn More</span>
      <span class="btn btn-submit">Open Minequest</span>
    </div>
  </div>
<% end %>
